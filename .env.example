# Copy this file to .env and change the passwords before running.
#   cp .env.example .env
#
# .env is gitignored. Never commit real passwords.

# Icecast source password: Liquidsoap uses this to connect and publish the
# stream. The admin password is for Icecast's own web admin.
ICECAST_SOURCE_PASSWORD=change-me-source
ICECAST_ADMIN_PASSWORD=change-me-admin

# Ports exposed on your machine. Change these if 8000 or 8080 are taken (for
# example if you already run Icecast on 8000). If you change ICECAST_PORT, also
# update station.stream_port in config.yaml.
ICECAST_PORT=8000
WEB_PORT=8080

# Optional: API key for your LLM endpoint (only if you set services.llm in
# config.yaml and it requires a key). Leave blank for the built-in canned lines.
LLM_API_KEY=
